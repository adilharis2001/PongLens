# Supabase project settings — find these in
# Supabase Dashboard -> Project Settings -> API
#
# The URL looks like https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon (public) API key. Safe to expose to the browser — row-level
# security is what actually protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Note: the service-role key is deliberately NOT used by the web app.
# Only the Mac Studio worker needs it, and it reads it from the macOS
# Keychain (see worker/README.md).
