# Supabase project settings — find these in
# Supabase Dashboard -> Project Settings -> API
#
# The URL looks like https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon (public) API key. Safe to expose to the browser — row-level
# security is what actually protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Note: the service-role key is deliberately NOT used by the web app.
# Only the Mac Studio worker needs it, and it reads it from the macOS
# Keychain (see worker/README.md).

# Cloudflare R2 — server-only (used by /api/upload-url and
# /api/download-url to mint presigned URLs). Values live in the macOS
# Keychain (ponglens-r2-account / ponglens-r2-key-id / ponglens-r2-secret)
# and in Vercel env vars. NEVER prefix these with NEXT_PUBLIC_.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
